diff --git a/source/backend/opencl/core/runtime/OpenCLRuntime.cpp b/source/backend/opencl/core/runtime/OpenCLRuntime.cpp
index f00cdfc..3333333 100644
--- a/source/backend/opencl/core/runtime/OpenCLRuntime.cpp
+++ b/source/backend/opencl/core/runtime/OpenCLRuntime.cpp
@@ -465,6 +465,39 @@ unsigned int OpenCLRuntime::getEventTime(cl::Event& event){
     return (unsigned int)((StopNanos - StartNanos) / 1000.0);
 }
+
+void OpenCLRuntime::finalizeFrameProfile() {
+#ifdef MNN_CL_PROFILING_CSV
+    mFrameRow.execute_end_ns = MNN::OpenCL::NowNs();
+    if (mFrameRow.execute_end_ns > mFrameRow.execute_begin_ns) {
+        mFrameRow.execute_total_us = (mFrameRow.execute_end_ns - mFrameRow.execute_begin_ns) / 1000;
+    }
+    uint32_t seq = 0;
+    for (const auto& item : mEvents) {
+        auto event = item.second;
+        cl_int res = event.wait();
+        MNN_CHECK_CL_SUCCESS(res, "clEvent");
+
+        MNN::OpenCL::KernelCsvRow row;
+        row.frame_id = mFrameRow.frame_id;
+        row.seq = ++seq;
+        row.name = item.first;
+        row.queued_ns = event.getProfilingInfo<CL_PROFILING_COMMAND_QUEUED>();
+        row.submit_ns = event.getProfilingInfo<CL_PROFILING_COMMAND_SUBMIT>();
+        row.start_ns = event.getProfilingInfo<CL_PROFILING_COMMAND_START>();
+        row.end_ns = event.getProfilingInfo<CL_PROFILING_COMMAND_END>();
+
+        mFrameRow.kernel_queue_to_submit_us_sum += (row.submit_ns > row.queued_ns) ? (row.submit_ns - row.queued_ns) / 1000 : 0;
+        mFrameRow.kernel_submit_to_start_us_sum += (row.start_ns > row.submit_ns) ? (row.start_ns - row.submit_ns) / 1000 : 0;
+        mFrameRow.kernel_gpu_us_sum += (row.end_ns > row.start_ns) ? (row.end_ns - row.start_ns) / 1000 : 0;
+        mFrameRow.num_kernels += 1;
+        MNN::OpenCL::CsvWriter::Get().AppendKernel(row);
+    }
+    MNN::OpenCL::CsvWriter::Get().AppendRun(mFrameRow);
+#endif
+}
 
