diff --git a/source/backend/opencl/core/MNNCLProfileUtils.hpp b/source/backend/opencl/core/MNNCLProfileUtils.hpp
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/source/backend/opencl/core/MNNCLProfileUtils.hpp
@@ -0,0 +1,230 @@
+#pragma once
+
+#include <stdint.h>
+#include <stdio.h>
+#include <mutex>
+#include <string>
+#include <chrono>
+#include <sstream>
+#include <vector>
+#include <unistd.h>
+#include <sys/syscall.h>
+
+#ifdef __ANDROID__
+#include <android/trace.h>
+#define MNN_ATRACE_BEGIN(name) ATrace_beginSection(name)
+#define MNN_ATRACE_END() ATrace_endSection()
+#define MNN_ATRACE_INT(name, value) ATrace_setCounter(name, value)
+#else
+#define MNN_ATRACE_BEGIN(name) ((void)0)
+#define MNN_ATRACE_END() ((void)0)
+#define MNN_ATRACE_INT(name, value) ((void)0)
+#endif
+
+namespace MNN {
+namespace OpenCL {
+
+inline uint64_t NowNs() {
+    return (uint64_t)std::chrono::duration_cast<std::chrono::nanoseconds>(
+        std::chrono::steady_clock::now().time_since_epoch()).count();
+}
+
+inline int32_t GetTid() {
+#ifdef __ANDROID__
+    return (int32_t)syscall(__NR_gettid);
+#else
+    return (int32_t)getpid();
+#endif
+}
+
+static inline const char* RunCsvPath() {
+    return "/data/local/tmp/mnn_opencl_run.csv";
+}
+
+static inline const char* KernelCsvPath() {
+    return "/data/local/tmp/mnn_opencl_kernel.csv";
+}
+
+struct RunCsvRow {
+    uint64_t frame_id = 0;
+    int32_t pid = 0;
+    int32_t tid = 0;
+    uint64_t execute_begin_ns = 0;
+    uint64_t execute_end_ns = 0;
+    uint64_t execute_total_us = 0;
+    uint64_t wait_us = 0;
+    uint64_t readback_us = 0;
+    uint64_t write_us = 0;
+    uint64_t map_us = 0;
+    uint64_t unmap_us = 0;
+    uint64_t kernel_gpu_us_sum = 0;
+    uint64_t kernel_queue_to_submit_us_sum = 0;
+    uint64_t kernel_submit_to_start_us_sum = 0;
+    uint32_t num_kernels = 0;
+    uint32_t fallback_count = 0;
+    uint32_t resize_happened = 0;
+};
+
+struct KernelCsvRow {
+    uint64_t frame_id = 0;
+    uint32_t seq = 0;
+    std::string name;
+    uint64_t queued_ns = 0;
+    uint64_t submit_ns = 0;
+    uint64_t start_ns = 0;
+    uint64_t end_ns = 0;
+};
+
+class CsvWriter {
+public:
+    static CsvWriter& Get() {
+        static CsvWriter g;
+        return g;
+    }
+
+    void AppendRun(const RunCsvRow& r) {
+        std::lock_guard<std::mutex> lk(mMutex);
+        EnsureRunHeader();
+        FILE* fp = fopen(RunCsvPath(), "a");
+        if (!fp) {
+            return;
+        }
+        fprintf(fp,
+                "%llu,%d,%d,%llu,%llu,%llu,%llu,%llu,%llu,%llu,%llu,%llu,%llu,%llu,%u,%u,%u\n",
+                (unsigned long long)r.frame_id,
+                (int)r.pid,
+                (int)r.tid,
+                (unsigned long long)r.execute_begin_ns,
+                (unsigned long long)r.execute_end_ns,
+                (unsigned long long)r.execute_total_us,
+                (unsigned long long)r.wait_us,
+                (unsigned long long)r.readback_us,
+                (unsigned long long)r.write_us,
+                (unsigned long long)r.map_us,
+                (unsigned long long)r.unmap_us,
+                (unsigned long long)r.kernel_gpu_us_sum,
+                (unsigned long long)r.kernel_queue_to_submit_us_sum,
+                (unsigned long long)r.kernel_submit_to_start_us_sum,
+                r.num_kernels,
+                r.fallback_count,
+                r.resize_happened);
+        fclose(fp);
+    }
+
+    void AppendKernel(const KernelCsvRow& r) {
+        std::lock_guard<std::mutex> lk(mMutex);
+        EnsureKernelHeader();
+        FILE* fp = fopen(KernelCsvPath(), "a");
+        if (!fp) {
+            return;
+        }
+        const uint64_t q2s = (r.submit_ns > r.queued_ns) ? (r.submit_ns - r.queued_ns) / 1000 : 0;
+        const uint64_t s2st = (r.start_ns > r.submit_ns) ? (r.start_ns - r.submit_ns) / 1000 : 0;
+        const uint64_t gpu = (r.end_ns > r.start_ns) ? (r.end_ns - r.start_ns) / 1000 : 0;
+        const uint64_t total = (r.end_ns > r.queued_ns) ? (r.end_ns - r.queued_ns) / 1000 : 0;
+        fprintf(fp,
+                "%llu,%u,%s,%llu,%llu,%llu,%llu,%llu,%llu,%llu,%llu\n",
+                (unsigned long long)r.frame_id,
+                r.seq,
+                r.name.c_str(),
+                (unsigned long long)r.queued_ns,
+                (unsigned long long)r.submit_ns,
+                (unsigned long long)r.start_ns,
+                (unsigned long long)r.end_ns,
+                (unsigned long long)q2s,
+                (unsigned long long)s2st,
+                (unsigned long long)gpu,
+                (unsigned long long)total);
+        fclose(fp);
+    }
+
+private:
+    void EnsureRunHeader() {
+        if (mRunHeaderDone) {
+            return;
+        }
+        FILE* fp = fopen(RunCsvPath(), "r");
+        if (!fp) {
+            fp = fopen(RunCsvPath(), "w");
+            if (fp) {
+                fprintf(fp,
+                        "frame_id,pid,tid,execute_begin_ns,execute_end_ns,execute_total_us,wait_us,readback_us,write_us,map_us,unmap_us,"
+                        "kernel_gpu_us_sum,kernel_queue_to_submit_us_sum,kernel_submit_to_start_us_sum,"
+                        "num_kernels,fallback_count,resize_happened\n");
+                fclose(fp);
+            }
+        } else {
+            fclose(fp);
+        }
+        mRunHeaderDone = true;
+    }
+
+    void EnsureKernelHeader() {
+        if (mKernelHeaderDone) {
+            return;
+        }
+        FILE* fp = fopen(KernelCsvPath(), "r");
+        if (!fp) {
+            fp = fopen(KernelCsvPath(), "w");
+            if (fp) {
+                fprintf(fp,
+                        "frame_id,seq,name,queued_ns,submit_ns,start_ns,end_ns,"
+                        "queue_to_submit_us,submit_to_start_us,gpu_exec_us,total_event_us\n");
+                fclose(fp);
+            }
+        } else {
+            fclose(fp);
+        }
+        mKernelHeaderDone = true;
+    }
+
+private:
+    std::mutex mMutex;
+    bool mRunHeaderDone = false;
+    bool mKernelHeaderDone = false;
+};
+
+} // namespace OpenCL
+} // namespace MNN
+
